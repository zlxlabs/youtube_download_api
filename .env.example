# ============================================================================
# YouTube Audio API - Environment Configuration
# ============================================================================
#
# 📖 Configuration Guide:
#    ✅ = Recommended settings (keep default)
#    ⚠️ = Important warnings (read carefully)
#    ❌ = Deprecated (do not modify)
#    💰 = Cost-related (may incur charges)
#    🔧 = Advanced (modify only if needed)
#
# 🚨 Common Pitfalls:
#    1. CDP_SCROLL_PROBABILITY / CDP_PAUSE_PROBABILITY are DEPRECATED
#    2. DOWNLOAD_CONCURRENCY must be 1 when using CDP human behavior
#    3. TikHub API costs $0.002 per call - use as fallback only
#    4. CDP requires external Chrome with remote debugging enabled
#
# 📚 Documentation: See docs/ folder for detailed guides
# ============================================================================

# ============ Docker Compose Port Mapping ============
HOST_PORT=8000
POT_PORT=4416

# ============ Required Configuration ============
API_KEY=your-secure-api-key-here
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# ============ WeCom Content Moderation ============
# Enable content moderation for WeCom notifications
WECOM_MODERATION_ENABLED=false
# Comma-separated list of sensitive word URLs
WECOM_MODERATION_URLS=
# Moderation strategy: block, replace, or pinyin_reverse (default)
WECOM_MODERATION_STRATEGY=pinyin_reverse

# ============ Service Configuration ============
HOST=0.0.0.0
DEBUG=false
# Base URL for file download links in notifications
BASE_URL=http://localhost:8000

# ============ PO Token Service ============
# PO Token Provider 实现类型 (rust / nodejs)
# rust:   Rust 版 (jim60105/bgutil-pot) - 内存占用低、镜像小、维护活跃，推荐
# nodejs: 原版 Node.js (brainicism/bgutil-ytdlp-pot-provider)
POT_PROVIDER_TYPE=rust
# PO Token Provider Docker 镜像 (必须与 POT_PROVIDER_TYPE 保持一致)
# rust   -> ghcr.io/jim60105/bgutil-pot:latest
# nodejs -> brainicism/bgutil-ytdlp-pot-provider:1.3.1
POT_PROVIDER_IMAGE=ghcr.io/jim60105/bgutil-pot:latest
# 使用宿主机 IP 访问 POT provider（172.17.0.1 是 Docker 默认网关）
POT_SERVER_URL=http://172.17.0.1:4416

# ============ Proxy Configuration ============
HTTP_PROXY=
HTTPS_PROXY=

# ============ Download Configuration ============
# ⚠️ CRITICAL: MUST be 1 when CDP_HUMAN_BEHAVIOR_ENABLED=true
# Concurrent downloads will cause browser page conflicts
# TODO: Multi-worker support not yet implemented
DOWNLOAD_CONCURRENCY=1

# ========== Task Interval Configuration (分级间隔策略) ==========
# 字幕任务间隔（轻量级，低风控）
TRANSCRIPT_INTERVAL_MIN=20
TRANSCRIPT_INTERVAL_MAX=40

# 音频/混合任务间隔（重量级，高风控）
AUDIO_INTERVAL_MIN=60
AUDIO_INTERVAL_MAX=600

# Deprecated: 保留向后兼容，建议使用上面的分级配置
TASK_INTERVAL_MIN=60
TASK_INTERVAL_MAX=600

AUDIO_QUALITY=128

# ============ Storage Configuration ============
DATA_DIR=./data
FILE_RETENTION_DAYS=60

# ============ Timezone ============
TZ=Asia/Shanghai

# ============ TikHub API ============
# 💰 TikHub API key for YouTube video downloading
# Get your API key from: https://tikhub.io
# ⚠️ COST: $0.002 per API call (paid service)
# 💡 TIP: Use as fallback only (set in AUDIO_DOWNLOAD_PRIORITY after free options)
TIKHUB_API_KEY=

# TikHub API response cache TTL in hours (1-12)
# Default: 3 hours (conservative, YouTube links usually valid for 6-12h)
# Purpose: Avoid duplicate API calls within short time (cost saving)
TIKHUB_CACHE_TTL_HOURS=3

# ============ YouTube Data API v3 ============
# YouTube Data API v3 key for metadata fetching (official API)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Quota: 10,000 units/day (videos.list = 1 unit)
# Purpose: Official, stable metadata fetching (title, author, duration, etc.)
# Note: Only provides metadata, does NOT provide download links
YOUTUBE_DATA_API_KEY=

# ============ CDP Downloader Configuration ============
# 🌟 Chrome DevTools Protocol downloader (uses real browser for authentication)
# 🎯 Purpose: Reduce 403 errors by using real browser cookies and TLS fingerprinting
# 📋 Requires: External Chrome running with remote debugging enabled
#
# 🚀 Quick Start:
#    1. Start Chrome with: chrome --remote-debugging-port=9222 --user-data-dir=/tmp/chrome
#    2. Set CDP_ENABLED=true
#    3. Set CDP_URLS=http://127.0.0.1:9222
#    4. Add "cdp" to AUDIO_DOWNLOAD_PRIORITY
#
# ⚠️ IMPORTANT: CDP is RECOMMENDED for production to avoid YouTube 403 errors

# ✅ Enable CDP downloader (requires external Chrome)
# Set to true after starting external Chrome with remote debugging
CDP_ENABLED=false

# CDP endpoint URLs (comma-separated, supports multiple instances for failover)
# Example: http://127.0.0.1:9222,http://192.168.1.100:9222
CDP_URLS=http://127.0.0.1:9222

# CDP connection timeout in seconds (5-120)
CDP_TIMEOUT=30

# Failover strategy: sequential (ordered) or random
CDP_FAILOVER_STRATEGY=sequential

# Enable PO Token support (required for videos hit by YouTube GVS experiment)
# Requires pot-provider service running (included in docker-compose)
CDP_ENABLE_POT_TOKEN=true

# Use curl_cffi for TLS fingerprinting (recommended)
CDP_USE_CURL_CFFI=true

# CDP health check interval in seconds (60-3600)
CDP_HEALTH_CHECK_INTERVAL=300

# Number of CDP connection retries (1-5)
CDP_CONNECTION_RETRY=3

# CDP circuit breaker: consecutive failure threshold (1-10)
CDP_CIRCUIT_FAILURE_THRESHOLD=3

# CDP circuit breaker: timeout in seconds (300-7200, default: 30 minutes)
CDP_CIRCUIT_TIMEOUT=1800

# CDP circuit breaker: success threshold in half-open state (1-5)
CDP_CIRCUIT_HALF_OPEN_SUCCESS=2

# CDP connection failure notification cooldown in seconds (300-86400)
CDP_NOTIFY_COOLDOWN=3600

# CDP max connections (currently only 1 is supported, reserved for future)
CDP_MAX_CONNECTIONS=1

# CDP transcode configuration
# Transcode downloaded audio to m4a format (default: false, keep original format to save time)
# Set to true if you need unified m4a format output
CDP_TRANSCODE_TO_M4A=false

# CDP multipart download (experimental, for large files)
# Enable multipart download (split file into chunks and download concurrently)
CDP_ENABLE_MULTIPART=false
# Number of chunks (recommended: 4-8 to balance speed and anti-crawler risk)
CDP_MULTIPART_CHUNKS=6
# Minimum file size to enable multipart (bytes, default: 1MB)
CDP_MULTIPART_MIN_SIZE=1048576

# ========== CDP Human Behavior Simulation Configuration ==========
# ✨ Simulate real human browsing behavior to reduce YouTube bot detection risk
# ✅ Background tasks run asynchronously after main download completes (no blocking)
#
# ⚠️ IMPORTANT: Requires DOWNLOAD_CONCURRENCY=1
#    Concurrent tasks will interfere with each other's browser pages
#
# 📖 How it works:
#    1. Opens video in browser, extracts cookies/headers (2-3s)
#    2. Downloads audio in background
#    3. Meanwhile, simulates human behavior (scroll, watch, pause) to avoid bot detection

# ✅ Enable human behavior simulation (recommended for production)
CDP_HUMAN_BEHAVIOR_ENABLED=true

# Quick mode: skip human behavior simulation (for testing/debugging only)
CDP_QUICK_MODE=false

# Video watch duration range (seconds, randomized)
# Recommended: 20-40s for realistic simulation
CDP_WATCH_DURATION_MIN=20
CDP_WATCH_DURATION_MAX=40

# Page alive duration before closing (seconds, randomized)
# Recommended: 30-60s to avoid suspicious patterns
CDP_PAGE_ALIVE_MIN=30
CDP_PAGE_ALIVE_MAX=60

# ========== Behavior Probabilities (DEPRECATED) ==========
# ⚠️ WARNING: These configs are DEPRECATED and no longer used
# They are kept only for backward compatibility

# [DEPRECATED] CDP_SCROLL_PROBABILITY - no longer used
# Scrolling behavior is now handled internally with realistic layering:
#   - 40% no scroll (watching video only)
#   - 35% light scroll (1-2 times, 200-400px, browsing title/description)
#   - 20% medium scroll (2-3 times, 400-800px, checking comments)
#   - 5% heavy scroll (3-5 times, may scroll back, deep reading)
# This config has NO EFFECT - do not modify
CDP_SCROLL_PROBABILITY=0.8

# [DEPRECATED] CDP_PAUSE_PROBABILITY - no longer used
# Pause behavior is now automatic (not probability-based):
#   - After watching, if this is the last page, video is ALWAYS paused
#   - Then page stays alive for CDP_PAGE_ALIVE_MIN/MAX seconds
#   - This prevents continuous playback and saves resources
# This config has NO EFFECT - do not modify
CDP_PAUSE_PROBABILITY=0.2

# ========== Video Play Duration Control (Smart) ==========
# ✨ Intelligently control video play duration based on video total length
# 🎯 Prevents videos from playing continuously overnight when no new tasks arrive
#
# 📐 Calculation formula:
#    play_duration = video_duration × random(PLAY_RATIO_MIN, PLAY_RATIO_MAX)
#    play_duration = clamp(play_duration, MIN_PLAY_DURATION, MAX_PLAY_DURATION)
#
# 💡 Example: 10-minute (600s) video
#    → 600s × random(0.2, 0.4) = 120-240s (2-4 minutes)
#    → Realistic human behavior (few people watch 100% of videos)

# ✅ Minimum play duration (seconds, avoid short videos playing too briefly)
# Recommended: 30s (applies when calculated duration < minimum)
CDP_MIN_PLAY_DURATION=30

# ✅ Maximum play duration (seconds, cap long video playback)
# Recommended: 600s (10 minutes, applies when calculated duration > maximum)
# ⚠️ WARNING: Too high may waste resources; too low may look suspicious
CDP_MAX_PLAY_DURATION=600

# ✅ Play ratio range (percentage of video total duration)
# Recommended: 0.2-0.4 (play 20%-40% of video, more human-like)
# ⚠️ WARNING: Do NOT set to 1.0 (100%) - unrealistic and wastes resources
CDP_PLAY_RATIO_MIN=0.2
CDP_PLAY_RATIO_MAX=0.4

# 🔄 Behavior: After watching, if this is the last page, pause video automatically
# Then keep page alive for CDP_PAGE_ALIVE_MIN/MAX seconds (30-60s default)
# This prevents continuous playback and saves resources

# ============ Downloader Priority Configuration ============
# ✨ Control which downloader to try first for different operations
# 📋 Available downloaders:
#    - youtube_data_api: Official API (free, 10k quota/day, metadata only)
#    - ytdlp: Open source (free, may trigger rate limit)
#    - tikhub: Paid API ($0.002/call, stable, no rate limit)
#    - cdp: Chrome DevTools Protocol (free, requires external Chrome, best for audio)
#
# 💡 Strategy: Use free options first, fallback to paid when needed

# ✅ Metadata fetching priority (prefer free)
# Recommended: youtube_data_api,ytdlp,tikhub (free → free → paid)
METADATA_PRIORITY=youtube_data_api,ytdlp,tikhub

# ✅ Transcript-only download priority (CDP first for fresh cookies, then fallback)
# Recommended: cdp,ytdlp,tikhub (CDP → free → paid)
# ⚠️ Note: CDP now supports subtitle download with fresh cookies
TRANSCRIPT_ONLY_PRIORITY=cdp,ytdlp,tikhub

# ✅ Audio download priority (CDP first for lower 403 rate, then free, then paid)
# Recommended: cdp,ytdlp,tikhub (CDP → free → paid)
# ⚠️ IMPORTANT: CDP requires CDP_ENABLED=true and external Chrome running
AUDIO_DOWNLOAD_PRIORITY=cdp,ytdlp,tikhub


# ============ Circuit Breaker Configuration ============
# Enable circuit breaker to protect against persistent failures
CIRCUIT_BREAKER_ENABLED=true
# Number of consecutive failures to trigger circuit breaker
CIRCUIT_BREAKER_THRESHOLD=5
# Circuit breaker timeout in seconds (how long to wait before retry)
CIRCUIT_BREAKER_TIMEOUT=1800
# Maximum calls allowed in half-open state (testing recovery)
CIRCUIT_BREAKER_HALF_OPEN_CALLS=3

# ============ Optional: Cookie File Path ============
COOKIE_FILE=

# ============ Optional: Dry Run Mode ============
DRY_RUN=false

# ============ Manual Upload Configuration ============
MANUAL_UPLOAD_ENABLED=true
MANUAL_UPLOAD_MAX_SIZE_MB=500
MANUAL_UPLOAD_ALLOWED_VIDEO_FORMATS=.mp4,.webm,.mkv,.avi,.mov
MANUAL_UPLOAD_ALLOWED_AUDIO_FORMATS=.m4a,.mp3,.aac,.opus,.wav,.flac,.ogg
